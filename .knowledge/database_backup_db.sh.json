{"is_source_file": true, "format": "bash", "description": "A shell script for backing up various database types (SQLite, PostgreSQL, MySQL, MongoDB) on a Unix-like system. It automatically detects the presence and type of the database and performs the appropriate backup procedure.", "external_files": ["/usr/lib/postgresql/", "/var/run/mysqld/mysqld.sock"], "external_methods": ["ls", "cp", "sudo -u postgres pg_isready", "pg_dump", "mysqladmin", "mysql", "mysqldump", "mongosh", "mongodump"], "published": [], "classes": [], "methods": [], "calls": ["ls /usr/lib/postgresql/", "cp \"${DB_NAME}\" \"database_backup.db\"", "sudo -u postgres ${PG_BIN}/pg_isready -p ${DB_PORT}", "${PG_BIN}/pg_dump", "mysqladmin ping -h localhost -P ${DB_PORT} --silent", "sudo mysqladmin ping --socket=/var/run/mysqld/mysqld.sock --silent", "mysql -h localhost -P ${DB_PORT} -u ${DB_USER} -p${DB_PASSWORD}", "mysqldump -h localhost -P ${DB_PORT} -u ${DB_USER} -p${DB_PASSWORD}", "mysql -h localhost -P ${DB_PORT} -u root -p${DB_PASSWORD}", "sudo mysql --socket=/var/run/mysqld/mysqld.sock -u root -p${DB_PASSWORD}", "sudo mysqldump --socket=/var/run/mysqld/mysqld.sock -u root -p${DB_PASSWORD}", "mongosh --port ${DB_PORT} --eval \"db.adminCommand('ping')\"", "mongodump --port ${DB_PORT} --db ${DB_NAME} --archive=database_backup.archive --quiet"], "search-terms": ["backup_db.sh", "database backup script", "SQLite", "PostgreSQL", "MySQL", "MongoDB", "database detection", "unix shell", "database backup"], "state": 2, "file_id": 2, "knowledge_revision": 13, "git_revision": "87b87e2e10c0dec54b24b83e96683b8e21dff9b5", "hash": "7af9aa35fa4940f934d83f6e2621b732", "format-version": 4, "code-base-name": "database", "filename": "database/backup_db.sh", "revision_history": [{"13": "87b87e2e10c0dec54b24b83e96683b8e21dff9b5"}]}